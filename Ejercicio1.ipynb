--3. Define las siguientes funciones:

--Devuelve el doble de un número.
doble :: Int -> Int
doble x = x*2
doble 15

--doble 15 = 30


--Devuelve True si la edad ingresada es mayor o igual a 18.
esMayorEdad :: Int -> Bool
esMayorEdad x = x>= 18
esMayorEdad 17

--esMayorEdad False

--Calcula el área de un círculo dado su radio.
areaCirculo :: Float -> Float
areaCirculo x = (x^2)* pi
areaCirculo 1

--areaCirculo = 3.14...
--Pista: Usa pi que ya está definido en Haskell.

